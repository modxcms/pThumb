{
  "name": "pThumb",
  "lowCaseName": "phpthumbof",
  "description": "A better phpThumbOf",
  "author": "MODx",
  "version": "2.4.0",
  "package": {
    "menus": [],
    "elements": {
      "chunks": [],
      "plugins": [{
        "name": "phpThumbOfCacheManager",
        "description": "Handles cache cleaning when clearing the Site Cache.",
        "file": "phpthumbofcachemanager.plugin.php",
        "events": [
          "OnSiteRefresh"
        ]
      }],
      "snippets": [{
        "name": "phpthumbof",
        "description": "Identical to pthumb. Retained for backwards compatibility.\nDocumentation: https://github.com/oo12/phpThumbOf",
        "file": "phpthumbof.snippet.php",
        "properties": [{
          "name": "debug",
          "value": false,
          "description": "prop_pthumb.debug_desc",
          "type": "combo-boolean",
          "lexicon": "phpthumbof:default"
        }]
      },{
        "name": "pthumb",
        "description": "Identical to phpthumbof. Better for future compatibility.\nDocumentation: https://github.com/oo12/phpThumbOf",
        "file": "phpthumbof.snippet.php",
        "properties": [{
          "name": "debug",
          "value": false,
          "description": "prop_pthumb.debug_desc",
          "type": "combo-boolean",
          "lexicon": "phpthumbof:default"
        }]
      }]
    },
    "systemSettings": [{
      "key": "use_resizer",
      "value": false,
      "area": "Images",
      "namespace": "",
      "type": "combo-boolean"
    },{
      "key": "global_defaults",
      "area": "Images",
      "namespace": ""
    },{
      "key": "remote_timeout",
      "value": 5,
      "area": "Other",
      "namespace": ""
    },{
      "key": "postfix_property_hash",
      "value": true,
      "area": "Cache [phpThumbOf]",
      "type": "combo-boolean"
    },{
      "key": "cache_path",
      "area": "Cache [phpThumbOf]"
    },{
      "key": "cache_url",
      "area": "Cache [common]"
    },{
      "key": "clean_level",
      "value": "0",
      "area": "Cache [common]"
    },{
      "key": "use_ptcache",
      "value": false,
      "area": "Cache [pThumb]",
      "type": "combo-boolean"
    },{
      "key": "ptcache_location",
      "value": "assets/image-cache",
      "area": "Cache [pThumb]"
    },{
      "key": "ptcache_images_basedir",
      "value": "assets",
      "area": "Cache [pThumb]"
    },{
      "key": "check_mod_time",
      "value": false,
      "area": "Cache [pThumb]",
      "type": "combo-boolean"
    },{
      "key": "s3_output",
      "area": "Amazon S3"
    },{
      "key": "s3_headers",
      "area": "Amazon S3",
      "type": "textarea"
    },{
      "key": "s3_multi_img",
      "value": false,
      "area": "Amazon S3",
      "type": "combo-boolean"
    },{
      "key": "s3_cache_path",
      "area": "Amazon S3"
    }]
  },
  "build": {
    "readme": "docs/readme.txt",
    "license": "docs/license.txt",
    "changelog": "docs/changelog.txt",
    "resolver": {
      "after": [
        "phpthumbof.resolver.php"
      ]
    }
  }
}